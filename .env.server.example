# server 用（雛形）。実体は .env.server にコピー（コミットしない）。
PORT=4000
# 実行環境。development 以外（未設定含む）では dev ログインバイパスは無効。
NODE_ENV=development
# web オリジン（CORS 許可・better-auth trustedOrigins 用）。
WEB_ORIGIN=http://localhost:5173
# better-auth
BETTER_AUTH_SECRET=generate-a-long-random-string
BETTER_AUTH_URL=http://localhost:4000
# Google OAuth（各自で取得。公開リポに実値を入れない）。
# 両方揃った時だけ Google ソーシャルログインが有効化される。未設定なら
# dev ログインバイパス（/api/dev/login, NODE_ENV=development 限定）で動作確認する。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# BlobStore（local | s3。prd/02 §7）。開発既定は compose の SeaweedFS を s3 アダプタで使う。
# 本番は Cloudflare R2 の endpoint / bucket / credentials を同じ変数に入れる。
BLOB_STORE=s3
S3_ENDPOINT=http://seaweedfs:8333
S3_BUCKET=hmf-images
S3_REGION=auto
# 開発（SeaweedFS 既定構成）は認証なしのためダミーで良い。R2 では実クレデンシャル。
S3_ACCESS_KEY_ID=dev
S3_SECRET_ACCESS_KEY=dev-secret
# 開発のみ true: 初回アクセス時にバケットを自動作成（R2 はバケット事前作成のため未設定/false）。
S3_ENSURE_BUCKET=true
# local を使う場合:
# BLOB_STORE=local
# BLOB_LOCAL_DIR=/workspace/packages/server/.blob

# スクショ自動解析の worker API 認証（shared secret。worker 側 .env.worker と同じ値。prd/04 §9.2）。
# 未設定なら worker API 全体が無効（自動解析は動かない）。
WORKER_API_TOKEN=generate-another-long-random-string
