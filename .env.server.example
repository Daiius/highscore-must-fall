# server 用（雛形）。実体は .env.server にコピー（コミットしない）。
PORT=4000
# 実行環境。development 以外（未設定含む）では dev ログインバイパスは無効。
NODE_ENV=development
# web オリジン（CORS 許可・better-auth trustedOrigins 用）。
WEB_ORIGIN=http://localhost:5173
# better-auth
BETTER_AUTH_SECRET=generate-a-long-random-string
BETTER_AUTH_URL=http://localhost:4000
# Google OAuth（各自で取得。公開リポに実値を入れない）。
# 両方揃った時だけ Google ソーシャルログインが有効化される。未設定なら
# dev ログインバイパス（/api/dev/login, NODE_ENV=development 限定）で動作確認する。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# BlobStore（MVP=local）。将来 R2/S3 に切り替え。
BLOB_DRIVER=local
BLOB_LOCAL_DIR=/workspace/packages/server/.blob
