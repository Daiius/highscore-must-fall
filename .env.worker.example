# worker 用（雛形）。実体は .env.worker にコピー（コミットしない）。
# worker は compose に含めず、server とは分離した実行環境のホスト上で
# `pnpm --filter worker daemon` として動かす（prd/04 §9.2。具体構成は非公開の運用メモ）。

# server の worker API エンドポイント。
WORKER_SERVER_URL=http://localhost:4000
# server 側 .env.server の WORKER_API_TOKEN と同じ値（shared secret）。
WORKER_API_TOKEN=same-secret-as-server
# queued が無いときの polling 間隔（ms）。
WORKER_POLL_INTERVAL_MS=15000

# LLM CLI のコマンドテンプレート。使用する CLI・引数は運用者が注入する
# （公開リポにツール固有名を置かない方針。prd/04 §9.2）。プレースホルダ:
#   {schema}        … 出力 JSON Schema のファイルパス
#   {schema_inline} … 同スキーマの JSON 文字列（inline 渡しの CLI 用）
#   {output}        … 出力 JSON の書き込み先パス（使わなければ stdout から読む）
#   {images}        … 画像パス列。{images:PREFIX} で各パスの前置詞を指定（例 {images:-i }）
#   {model}         … WORKER_LLM_MODEL の値
# プロンプトは stdin で渡される。例（架空の CLI）:
WORKER_LLM_COMMAND=your-llm-cli extract --schema {schema} --out {output} {images:-i }
WORKER_LLM_MODEL=
# LLM 実行のタイムアウト（ms）。server 側 lease（30分）より短くする。
WORKER_LLM_TIMEOUT_MS=900000
