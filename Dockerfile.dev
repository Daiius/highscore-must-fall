# 開発用の共通イメージ（server / web / worker で共用）。
# 本番イメージは別途（PRD / Phase 実装時に用意）。
FROM node:22-slim

# pnpm（corepack 経由。バージョンは package.json の packageManager に従う）
RUN corepack enable

WORKDIR /workspace

# 依存解決に必要なマニフェスト類を先にコピー（レイヤキャッシュを効かせる）
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY packages/shared/package.json   packages/shared/package.json
COPY packages/database/package.json packages/database/package.json
COPY packages/server/package.json   packages/server/package.json
COPY packages/web/package.json      packages/web/package.json
# pnpm の prepare フック（.githooks/install.sh）が install 時に呼ばれる。
# git 管理外では自身で exit 0 するが、ファイルが存在しないと sh が開けず落ちるため先にコピーする。
COPY .githooks .githooks

RUN pnpm install --frozen-lockfile || pnpm install

# ソース本体。起動後の変更は docker compose watch の sync が送る（bind mount は使わない）が、
# **起動時点のソースはこの COPY で焼かれたもの**になる。したがってイメージを再ビルドせずに起動すると、
# 前回ビルド時の古いソースでコンテナが動く（watch は起動後の編集しか同期しない）。
# → `pnpm dev` は `--build` 付きで起動する（package.json）。依存レイヤはキャッシュが効くので速い。
COPY . .

EXPOSE 4000 5173
