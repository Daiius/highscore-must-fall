# database パッケージ用の環境変数の雛形。
# 実体は .env.database（gitignore 対象・コミットしない）にコピーして埋める。
# drizzle.config.ts / src/index.ts が process.loadEnvFile('.env.database') で読み込む。
# docker compose 実行時は compose 側の env が優先される（このファイルは主にローカル CLI 用）。

DB_HOST=localhost
DB_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=highscore_must_fall
